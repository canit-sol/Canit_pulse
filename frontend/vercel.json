{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-railway-app.up.railway.app/api/:path*"
    },
    {
      "source": "/:file((?:.*\\.(?:png|ico|svg|jpg|jpeg|gif|webp|css|js|woff|woff2)))$",
      "destination": "/:file"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}